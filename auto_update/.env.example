# Philippines Fintech Daily Brief - Environment Variables
# Copy this file to .env and fill in your API keys

# ─── OpenAI API (optional, for Chinese summaries) ───
# Supports OpenAI, Azure OpenAI, or any compatible API
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── SerpAPI (optional, for better web search) ──────
# Get free key at https://serpapi.com (100 searches/month free)
# If not set, falls back to Google News RSS (free, unlimited)
SERPAPI_KEY=your-serpapi-key-here
